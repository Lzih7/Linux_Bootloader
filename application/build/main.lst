  32:../application/src/main.c ****   
  33:../application/src/main.c ****   /* Initialize UART (optional, for debugging output) */
  34:../application/src/main.c ****   // uart_init();
  35:../application/src/main.c ****   
  36:../application/src/main.c ****   /* Application main loop */
  37:../application/src/main.c ****   while (1) {
  38:../application/src/main.c ****     /* Toggle LED at slower rate than bootloader */
  39:../application/src/main.c ****     led_toggle();
  40:../application/src/main.c ****     delay_ms(LED_BLINK_DELAY_MS);
  41:../application/src/main.c ****   }
  42:../application/src/main.c **** }
