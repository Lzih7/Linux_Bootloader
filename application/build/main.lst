  19:../application/src/main.c **** void main(void)
  20:../application/src/main.c **** {
  21:../application/src/main.c ****   /* Relocate vector table to application region (important!) */
  22:../application/src/main.c ****   /* Bootloader sets VTOR to 0x08000000, Application needs 0x08010000 */
  23:../application/src/main.c ****   __disable_irq();
