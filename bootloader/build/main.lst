ARM GAS  /tmp/ccWVU6UO.s 			page 2


  32:../bootloader/src/main.c ****   
  33:../bootloader/src/main.c ****   /* Check if application is valid */
  34:../bootloader/src/main.c ****   if (validate_application() == BOOTLOADER_OK) {
  35:../bootloader/src/main.c ****     /* Application is valid, jump to it after short delay */
  36:../bootloader/src/main.c ****     boot_timeout = BOOT_TIMEOUT_MS;
  37:../bootloader/src/main.c ****     
  38:../bootloader/src/main.c ****     /* Wait for timeout (LED fast blink) */
  39:../bootloader/src/main.c ****     while (boot_timeout > 0) {
  40:../bootloader/src/main.c ****       led_toggle();
  41:../bootloader/src/main.c ****       delay_ms(100);
  42:../bootloader/src/main.c ****       boot_timeout -= 100;
  43:../bootloader/src/main.c ****     }
  44:../bootloader/src/main.c ****     
  45:../bootloader/src/main.c ****     /* Jump to application */
  46:../bootloader/src/main.c ****     bootloader_jump_to_app();
  47:../bootloader/src/main.c ****   } else {
  48:../bootloader/src/main.c ****     /* No valid application, stay in bootloader (LED solid on) */
  49:../bootloader/src/main.c ****     bootloader_error_loop();
  50:../bootloader/src/main.c ****   }
  51:../bootloader/src/main.c ****   
  52:../bootloader/src/main.c ****   /* Should never reach here */
  53:../bootloader/src/main.c ****   while (1) {
  54:../bootloader/src/main.c ****     bootloader_error_loop();
  55:../bootloader/src/main.c ****   }
  56:../bootloader/src/main.c **** }
