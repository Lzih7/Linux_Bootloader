 130:../common/cmsis/device/system_stm32f4xx.c ****   /* This variable is updated in three ways:
 131:../common/cmsis/device/system_stm32f4xx.c ****       1) by calling CMSIS function SystemCoreClockUpdate()
 132:../common/cmsis/device/system_stm32f4xx.c ****       2) by calling HAL API function HAL_RCC_GetHCLKFreq()
 133:../common/cmsis/device/system_stm32f4xx.c ****       3) each time HAL_RCC_ClockConfig() is called to configure the system clock frequency 
 134:../common/cmsis/device/system_stm32f4xx.c ****          Note: If you use this function to configure the system clock; then there
 135:../common/cmsis/device/system_stm32f4xx.c ****                is no need to call the 2 first functions listed above, since SystemCoreClock
 136:../common/cmsis/device/system_stm32f4xx.c ****                variable is updated automatically.
 137:../common/cmsis/device/system_stm32f4xx.c ****   */
 138:../common/cmsis/device/system_stm32f4xx.c ****   uint32_t SystemCoreClock = 16000000;
 139:../common/cmsis/device/system_stm32f4xx.c **** const uint8_t AHBPrescTable[16] = {0, 0, 0, 0, 0, 0, 0, 0, 1, 2, 3, 4, 6, 7, 8, 9};
